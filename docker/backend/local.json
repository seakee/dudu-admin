{
  "system": {
    "name": "dudu-admin-api",
    "route_prefix": "dudu-admin-api",
    "run_mode": "release",
    "http_port": ":8080",
    "read_timeout": 60,
    "write_timeout": 60,
    "version": "local-compose",
    "debug_mode": false,
    "default_lang": "zh-CN",
    "jwt_secret": "${DUDU_ADMIN_BACKEND_JWT_SECRET}",
    "token_expire": 604800,
    "admin": {
      "safe_code_expire_in": 180,
      "token_expire_in": 2592000,
      "jwt_secret": "${DUDU_ADMIN_BACKEND_ADMIN_JWT_SECRET}",
      "auth_rate_limit": {
        "enable": true,
        "window_seconds": 60,
        "max_requests": 20
      },
      "oauth": {
        "redirect_url": "http://localhost:3000/auth/callback",
        "feishu": {
          "client_id": "",
          "client_secret": "",
          "oauth_url": "https://open.feishu.cn/open-apis/authen/v1/authorize"
        },
        "wechat": {
          "corp_id": "",
          "agent_id": "",
          "corp_secret": "",
          "oauth_url": "https://open.weixin.qq.com/connect/oauth2/authorize",
          "proxy_url": ""
        }
      },
      "webauthn": {
        "rp_id": "localhost",
        "rp_display_name": "Dudu Admin",
        "rp_origins": [
          "http://localhost:3000"
        ],
        "challenge_expire_in": 180,
        "user_verification": "preferred"
      }
    }
  },
  "log": {
    "driver": "stdout",
    "level": "info",
    "path": "storage/logs/"
  },
  "databases": [
    {
      "enable": true,
      "db_type": "mysql",
      "db_host": "mysql",
      "db_port": 3306,
      "db_name": "dudu-admin-api",
      "db_username": "dudu-admin-api",
      "db_password": "${DUDU_ADMIN_MYSQL_PASSWORD}",
      "charset": "utf8mb4",
      "db_max_idle_conn": 10,
      "db_max_open_conn": 50,
      "conn_max_lifetime": 3,
      "conn_max_idle_time": 1
    },
    {
      "enable": false,
      "db_type": "mongo",
      "db_name": "dudu-admin-api",
      "db_host": "mongodb://127.0.0.1:27017",
      "db_username": "dudu-admin-api",
      "db_password": "",
      "db_max_idle_conn": 10,
      "db_max_open_conn": 50,
      "auth_mechanism": "SCRAM-SHA-1",
      "conn_max_lifetime": 1,
      "conn_max_idle_time": 1
    }
  ],
  "cache": {
    "driver": "redis",
    "prefix": "dudu-admin-api"
  },
  "redis": [
    {
      "enable": true,
      "name": "dudu-admin-api",
      "host": "redis:6379",
      "auth": "",
      "max_idle": 30,
      "max_active": 100,
      "idle_timeout": 30,
      "prefix": "dudu-admin-api",
      "db": 0
    }
  ],
  "kafka": {
    "brokers": [],
    "max_retry": 1,
    "client_id": "dudu-admin-api",
    "producer_enable": false,
    "consumer_enable": false,
    "consumer_group": "",
    "consumer_topics": [],
    "consumer_auto_submit": true
  },
  "monitor": {
    "panic_robot": {
      "enable": false,
      "wechat": {
        "enable": false,
        "push_url": ""
      },
      "feishu": {
        "enable": false,
        "push_url": ""
      }
    }
  },
  "notify": {
    "default_channel": "lark",
    "default_level": "info",
    "lark": {
      "enable": false,
      "default_send_channel_name": "dudu-admin-api",
      "channel_size": 0,
      "pool_size": 0,
      "bot_webhooks": {},
      "larks": {}
    }
  }
}
