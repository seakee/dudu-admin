# 可直接使用：docker compose --env-file .env.compose.example up --build
# 如果前后端仓库目录结构与当前示例不同，请修改 DUDU_ADMIN_API_DIR
DUDU_ADMIN_API_DIR=../../Golang/src/github.com/seakee/dudu-admin-api
DUDU_ADMIN_FRONTEND_PORT=3000
DUDU_ADMIN_API_PORT=8080
DUDU_ADMIN_MYSQL_PORT=3306
DUDU_ADMIN_REDIS_PORT=6379
DUDU_ADMIN_MYSQL_DATABASE=dudu-admin-api
DUDU_ADMIN_MYSQL_USER=dudu-admin-api
DUDU_ADMIN_MYSQL_PASSWORD=change-me-local-db-password
DUDU_ADMIN_MYSQL_ROOT_PASSWORD=change-me-local-root-password
DUDU_ADMIN_BACKEND_JWT_SECRET=local-compose-jwt-secret
DUDU_ADMIN_BACKEND_ADMIN_JWT_SECRET=local-compose-admin-jwt-secret
